# Semi-auto runner settings
SEMI_AUTO_MODE=off
SEMI_AUTO_RUN_ONCE=false
SEMI_AUTO_INTERVAL_MINUTES=1440

# Local mode (SEMI_AUTO_MODE=local)
SEMI_AUTO_LOCAL_TARGET_DIR=../SomeBackend/Config

# VPS mode (SEMI_AUTO_MODE=vps)
VPS_HOST=example.com
VPS_PORT=22
VPS_USER=ubuntu
VPS_KEY_PATH=./keys/vps_id_rsa
VPS_REMOTE_DIR=/home/ubuntu/backend/Config

# Optional command after upload (for restart/reload)
# VPS_POST_DEPLOY_CMD=sudo systemctl restart lawinserver
